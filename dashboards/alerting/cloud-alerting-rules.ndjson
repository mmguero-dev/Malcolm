###############################################################################
#  Malcolm – Cloud Infrastructure Logs: Real-Time Alerting Rules
#  OpenSearch Alerting (Alerting plugin) – Monitors & Triggers
#
#  Import via:  OpenSearch Dashboards → Alerting → Monitors → Import
#  Each NDJSON object is a single Monitor definition.
#
#  Covered log sources:
#    AWS  - VPC Flow, CloudTrail, ELB/ALB, S3, Route 53, RDS
#    Azure - NSG Flow Logs, Activity Logs, Application Gateway WAF
###############################################################################

{
  "type": "monitor",
  "name": "CLOUD-ALERT-01: Mass Unauthorized Access Attempts",
  "enabled": true,
  "schedule": { "period": { "interval": 5, "unit": "MINUTES" } },
  "inputs": [{
    "search": {
      "indices": ["arkime_sessions3-*"],
      "query": {
        "size": 0,
        "query": {
          "bool": {
            "filter": [
              { "range": { "@timestamp": { "gte": "now-5m" } } },
              { "terms": { "tags": ["unauthorized_access", "access_denied", "unauthorized_access_attempt"] } },
              { "terms": { "cloud.provider": ["aws", "azure"] } }
            ]
          }
        },
        "aggs": {
          "by_ip": {
            "terms": { "field": "source.ip", "size": 10, "min_doc_count": 10 }
          }
        }
      }
    }
  }],
  "triggers": [{
    "name": "More than 10 failed auth attempts from single IP in 5 min",
    "severity": "1",
    "condition": {
      "script": {
        "source": "ctx.results[0].hits.total.value > 10 || ctx.results[0].aggregations.by_ip.buckets.size() > 0",
        "lang": "painless"
      }
    },
    "actions": [{
      "name": "Log Alert",
      "destination_id": "",
      "message_template": {
        "source": "CRITICAL - Mass unauthorized access from cloud infrastructure:\nEvent count: {{ctx.results.0.hits.total.value}}\nTime: {{ctx.periodStart}} to {{ctx.periodEnd}}\nCheck Unified Multi-Cloud Security dashboard for details."
      }
    }]
  }]
}

{
  "type": "monitor",
  "name": "CLOUD-ALERT-02: DNS Tunneling / DGA Detected",
  "enabled": true,
  "schedule": { "period": { "interval": 5, "unit": "MINUTES" } },
  "inputs": [{
    "search": {
      "indices": ["arkime_sessions3-*"],
      "query": {
        "size": 0,
        "query": {
          "bool": {
            "filter": [
              { "range": { "@timestamp": { "gte": "now-5m" } } },
              { "terms": { "tags": ["potential_dns_tunneling", "potential_dga", "potential_amplification"] } },
              { "term": { "event.dataset": "aws.route53" } }
            ]
          }
        }
      }
    }
  }],
  "triggers": [{
    "name": "DNS tunneling or DGA activity detected",
    "severity": "1",
    "condition": {
      "script": {
        "source": "ctx.results[0].hits.total.value > 0",
        "lang": "painless"
      }
    },
    "actions": [{
      "name": "Log Alert",
      "destination_id": "",
      "message_template": {
        "source": "CRITICAL - DNS Tunneling or DGA activity detected via Route 53!\nEvents: {{ctx.results.0.hits.total.value}}\nTime window: {{ctx.periodStart}} to {{ctx.periodEnd}}\nInvestigate with AWS Route 53 DNS Analysis dashboard."
      }
    }]
  }]
}

