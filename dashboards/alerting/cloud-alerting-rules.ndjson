  "name": "CLOUD-ALERT-08: RDS Mass Authentication Failures",
  "enabled": true,
  "schedule": { "period": { "interval": 5, "unit": "MINUTES" } },
  "inputs": [{
    "search": {
      "indices": ["arkime_sessions3-*"],
      "query": {
        "size": 0,
        "query": {
          "bool": {
            "filter": [
              { "range": { "@timestamp": { "gte": "now-5m" } } },
              { "term": { "tags": "db_authentication_failure" } },
              { "term": { "event.dataset": "aws.rds" } }
            ]
          }
        }
      }
