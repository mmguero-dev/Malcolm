}

{
  "type": "monitor",
  "name": "CLOUD-ALERT-09: Large Data Exfiltration via S3 or ELB",
  "enabled": true,
  "schedule": { "period": { "interval": 15, "unit": "MINUTES" } },
  "inputs": [{
    "search": {
      "indices": ["arkime_sessions3-*"],
      "query": {
        "size": 0,
        "query": {
          "bool": {
            "filter": [
              { "range": { "@timestamp": { "gte": "now-15m" } } },
              { "terms": { "tags": ["large_download", "data_upload"] } },
              { "terms": { "event.dataset": ["aws.s3access", "aws.elb"] } }
            ]
          }
        },
        "aggs": {
          "total_bytes": { "sum": { "field": "http.response.bytes" } }
        }
      }
    }
  }],
  "triggers": [{
    "name": "Potential data exfiltration > 1 GB in 15 min",
    "severity": "2",
    "condition": {
      "script": {
        "source": "ctx.results[0].aggregations.total_bytes.value > 1073741824",
        "lang": "painless"
      }
    },
    "actions": [{
      "name": "Log Alert",
      "destination_id": "",
      "message_template": {
        "source": "HIGH - Potential large data exfiltration detected!\nTotal bytes: {{ctx.results.0.aggregations.total_bytes.value}}\nTime: {{ctx.periodStart}} to {{ctx.periodEnd}}\nCheck AWS S3 Access Logs and ELB dashboards for source IPs."
      }
    }]
  }]
}

{
  "type": "monitor",
  "name": "CLOUD-ALERT-10: Azure NSG Mass Port Scanning",
  "enabled": true,
  "schedule": { "period": { "interval": 5, "unit": "MINUTES" } },
  "inputs": [{
    "search": {
      "indices": ["arkime_sessions3-*"],
      "query": {
        "size": 0,
        "query": {
          "bool": {
            "filter": [
              { "range": { "@timestamp": { "gte": "now-5m" } } },
              { "term": { "tags": "potential_port_scan" } },
              { "term": { "event.dataset": "azure.nsgflowlogs" } }
            ]
          }
        },
        "aggs": {
          "by_src": {
            "terms": { "field": "source.ip", "size": 5, "min_doc_count": 20 }
          }
        }
      }
    }
  }],
  "triggers": [{
    "name": "Port scan detected in NSG flow logs (> 20 denied per IP)",
    "severity": "2",
    "condition": {
      "script": {
        "source": "ctx.results[0].aggregations.by_src.buckets.size() > 0",
        "lang": "painless"
      }
    },
    "actions": [{
      "name": "Log Alert",
      "destination_id": "",
      "message_template": {
        "source": "HIGH - Port scan activity detected in Azure NSG!\nDenied connections: {{ctx.results.0.hits.total.value}}\nTime: {{ctx.periodStart}} to {{ctx.periodEnd}}\nCheck Azure NSG Flow Logs dashboard for source IPs."
      }
    }]
  }]
}
