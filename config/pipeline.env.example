# Set to true to disable file scanning with Strelka
PIPELINE_DISABLED=false

# The number of strelka backend processes to run
STRELKA_BACKEND_PROCS=1

# Enabled Strelka scanners
STRELKA_SCANNERS=ScanBatch,ScanBmpEof,ScanBzip2,ScanClamav,ScanDmg,ScanDocx,ScanDonut,ScanEmail,ScanEncryptedDoc,ScanEncryptedZip,ScanEntropy,ScanExiftool,ScanGifEof,ScanGzip,ScanHtml,ScanIqy,ScanIso,ScanJarManifest,ScanJavascript,ScanJnlp,ScanJpegEof,ScanJson,ScanLibarchive,ScanLnk,ScanLsb,ScanLzma,ScanMacho,ScanManifest,ScanMsi,ScanOle,ScanOnenote,ScanPdf,ScanPe,ScanPgp,ScanPhp,ScanPkcs7,ScanPlist,ScanPngEof,ScanPyinstaller,ScanQr,ScanRar,ScanRpm,ScanRtf,ScanSevenZip,ScanSwf,ScanTar,ScanTnef,ScanTranscode,ScanUdf,ScanUpx,ScanUrl,ScanVb,ScanVba,ScanVhd,ScanVsto,ScanXar,ScanXl4ma,ScanXml,ScanYara,ScanZip,ScanZlib,ScanZstd

# Whether or not to regularly update rule definitions for file scanning engines
RULES_UPDATE_ENABLED=false

# Whether or not the default YARA ruleset will be ignored and only custom rules used
YARA_CUSTOM_RULES_ONLY=false

# values for tuning clamd (others are available, see strelka/docker-entrypoint.sh)
# Maximum number of concurrent clamd threads (MaxThreads)
CLAMD_MAX_THREADS=8
# Maximum number of queued items for clamd (MaxQueue)
CLAMD_MAX_QUEUE=200
# Maximum length the queue of pending connections may grow to for clamd (MaxConnectionQueueLength)
CLAMD_MAX_CONN_QUEUE=400
# Scan within archives and compressed files. With Strelka's archive scanners enabled,
# this should be "false" # to avoid duplicate processing.
CLAMD_SCAN_ARCHIVE=false